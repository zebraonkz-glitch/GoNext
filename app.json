{
  "expo": {
    "name": "GoNext",
    "slug": "gonext",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gonext",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gonext.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.gonext.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GoNext использует геолокацию для указания координат мест."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "GoNext использует галерею для прикрепления фотографий к местам.",
          "cameraPermission": "GoNext использует камеру для съёмки фотографий мест."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "GoNext использует контакты для добавления попутчиков."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
